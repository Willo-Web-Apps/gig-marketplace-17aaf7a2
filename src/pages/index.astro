---
import Base from '../layouts/Base.astro';
---
<Base title="Tasq — Keep 95% of What You Earn" description="Tasq charges just 5% on every task — while TaskRabbit takes up to 30%. Join the peer-to-peer task marketplace built for workers first.">

  <!-- ================================================================
       HERO — Dark near-black, rallying cry energy
       ================================================================ -->
  <section class="hero-noise relative min-h-screen flex items-center overflow-hidden bg-surface-900">
    <!-- Layered gradient lighting: amber glow upper-right, warm ember lower-left -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div style="position:absolute;inset:0;background:radial-gradient(ellipse 70% 60% at 80% 10%, oklch(0.75 0.16 75 / 0.18) 0%, transparent 70%);"></div>
      <div style="position:absolute;inset:0;background:radial-gradient(ellipse 55% 45% at 10% 90%, oklch(0.65 0.16 72 / 0.12) 0%, transparent 65%);"></div>
      <div style="position:absolute;inset:0;background:linear-gradient(185deg, transparent 40%, oklch(0.11 0.025 75 / 0.6) 100%);"></div>
    </div>

    <div class="relative z-10 w-full max-w-7xl mx-auto px-5 sm:px-8 lg:px-12 py-24 md:py-32">
      <div class="max-w-5xl">
        <!-- Eyebrow -->
        <div class="animate-slide-up inline-flex items-center gap-2 mb-8">
          <span class="inline-block w-2 h-2 rounded-full bg-brand-500"></span>
          <span class="text-brand-500 font-body font-600 text-sm uppercase tracking-widest">Peer-to-peer task marketplace</span>
        </div>

        <!-- Giant % anchor — visceral value prop -->
        <div class="animate-fade-in relative select-none pointer-events-none mb-[-0.15em]" aria-hidden="true">
          <span class="font-display text-[clamp(120px,20vw,220px)] leading-none text-brand-500 opacity-15 absolute -top-2 -left-2 blur-sm">95%</span>
          <span class="font-display text-[clamp(120px,20vw,220px)] leading-none text-brand-500 opacity-90 relative z-10">95%</span>
        </div>

        <!-- Hero headline -->
        <h1 class="font-display text-4xl sm:text-5xl md:text-6xl lg:text-7xl leading-[1.05] text-white animate-slide-up delay-100 mt-4 max-w-3xl">
          Keep 95% of What You Earn on Every Task
        </h1>

        <!-- Sub -->
        <p class="font-body text-lg md:text-xl text-white/65 mt-6 max-w-xl leading-relaxed animate-slide-up delay-200">
          Tasq charges just 5% — while TaskRabbit takes up to 30%. Join the platform built for workers.
        </p>

        <!-- CTAs -->
        <div class="mt-10 flex flex-col sm:flex-row gap-4 animate-slide-up delay-300">
          <a href="#join" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-brand-500 hover:bg-brand-600 text-surface-950 font-body font-700 text-base rounded-lg transition-colors duration-150">
            Start earning more today
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="#how-it-works" class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-white/20 text-white hover:bg-white/8 font-body font-600 text-base rounded-lg transition-colors duration-150">
            See how it works
          </a>
        </div>

        <!-- Micro-proof -->
        <p class="mt-6 text-white/35 text-sm font-body animate-slide-up delay-400">
          No subscription. No hidden fees. Just 5% per completed task.
        </p>
      </div>
    </div>
  </section>

  <!-- ================================================================
       IMPACT STATS — Dark warm, community movement feel
       ================================================================ -->
  <section class="bg-surface-950 py-16 md:py-20 border-y border-white/5">
    <div class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-12">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-4">
        <div class="text-center animate-count-up delay-100">
          <p class="font-display text-4xl md:text-5xl text-brand-500">$2.4M+</p>
          <p class="font-body text-sm text-white/50 mt-2 uppercase tracking-wide">Kept by workers</p>
        </div>
        <div class="text-center animate-count-up delay-200">
          <p class="font-display text-4xl md:text-5xl text-brand-500">48K+</p>
          <p class="font-body text-sm text-white/50 mt-2 uppercase tracking-wide">Tasks completed</p>
        </div>
        <div class="text-center animate-count-up delay-300">
          <p class="font-display text-4xl md:text-5xl text-brand-500">5%</p>
          <p class="font-body text-sm text-white/50 mt-2 uppercase tracking-wide">Platform fee. Always.</p>
        </div>
        <div class="text-center animate-count-up delay-400">
          <p class="font-display text-4xl md:text-5xl text-brand-500">$620</p>
          <p class="font-body text-sm text-white/50 mt-2 uppercase tracking-wide">Avg. saved vs. TaskRabbit / yr</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================================
       HOW IT WORKS — 3 steps, warm cream
       ================================================================ -->
  <section id="how-it-works" class="bg-surface-50 py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-12">
      <!-- Label -->
      <p class="font-body text-sm font-600 uppercase tracking-widest text-brand-500 mb-4">Simple by design</p>
      <h2 class="font-display text-4xl md:text-5xl lg:text-6xl text-surface-900 max-w-2xl leading-[1.1] mb-16">
        Get tasks done in three steps
      </h2>

      <div class="grid md:grid-cols-3 gap-10 md:gap-8">
        <!-- Step 1 -->
        <div class="relative">
          <div class="w-12 h-12 rounded-xl bg-brand-500 flex items-center justify-center mb-6">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          </div>
          <span class="absolute top-3 left-14 font-display text-6xl text-surface-200 leading-none select-none" aria-hidden="true">01</span>
          <h3 class="font-display text-2xl text-surface-900 mb-3 relative z-10">Post your task</h3>
          <p class="font-body text-base text-surface-800/65 leading-relaxed">Describe what you need — furniture assembly, yard work, moving help, or anything else. Set your budget and location.</p>
        </div>

        <!-- Step 2 -->
        <div class="relative">
          <div class="w-12 h-12 rounded-xl bg-brand-500 flex items-center justify-center mb-6">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <span class="absolute top-3 left-14 font-display text-6xl text-surface-200 leading-none select-none" aria-hidden="true">02</span>
          <h3 class="font-display text-2xl text-surface-900 mb-3 relative z-10">Match with a Tasker</h3>
          <p class="font-body text-base text-surface-800/65 leading-relaxed">Browse verified local Taskers with real reviews. Chat directly — no middlemen, no inflated quotes baked in to cover platform cuts.</p>
        </div>

        <!-- Step 3 -->
        <div class="relative">
          <div class="w-12 h-12 rounded-xl bg-brand-500 flex items-center justify-center mb-6">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><path d="M2 10h20"/></svg>
          </div>
          <span class="absolute top-3 left-14 font-display text-6xl text-surface-200 leading-none select-none" aria-hidden="true">03</span>
          <h3 class="font-display text-2xl text-surface-900 mb-3 relative z-10">Pay — Tasker keeps 95%</h3>
          <p class="font-body text-base text-surface-800/65 leading-relaxed">Secure payment processed on completion. Tasq takes only 5%. The Tasker keeps the rest. Every time. No surprises.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================================
       MEMBER SPOTLIGHTS — Warm cream, card grid
       ================================================================ -->
  <section class="bg-surface-100 py-24 md:py-32 border-t border-surface-200">
    <div class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-12">
      <p class="font-body text-sm font-600 uppercase tracking-widest text-brand-500 mb-4">Real workers. Real earnings.</p>
      <h2 class="font-display text-4xl md:text-5xl text-surface-900 max-w-xl leading-[1.1] mb-14">
        Taskers who finally kept what they earned
      </h2>

      <div class="grid md:grid-cols-3 gap-6">
        <!-- Worker card 1 -->
        <div class="bg-surface-50 border border-surface-200 rounded-2xl p-7 flex flex-col gap-5 hover:shadow-lg transition-shadow duration-200">
          <div class="flex items-center gap-4">
            <div class="w-14 h-14 rounded-full bg-brand-500/20 flex items-center justify-center font-display text-xl text-brand-600">MR</div>
            <div>
              <p class="font-body font-700 text-surface-900 text-base">Marcus R.</p>
              <p class="font-body text-sm text-surface-800/50">Handyman · Chicago, IL</p>
            </div>
          </div>
          <p class="font-body text-base text-surface-800/70 leading-relaxed italic">"I was giving TaskRabbit $280 a month in fees. On Tasq I kept every cent of that — same number of jobs. It's not even close."</p>
          <div class="mt-auto pt-4 border-t border-surface-200 flex items-baseline gap-2">
            <span class="font-display text-2xl text-brand-500">$3,360</span>
            <span class="font-body text-sm text-surface-800/45">extra kept per year</span>
          </div>
        </div>

        <!-- Worker card 2 -->
        <div class="bg-surface-50 border border-surface-200 rounded-2xl p-7 flex flex-col gap-5 hover:shadow-lg transition-shadow duration-200">
          <div class="flex items-center gap-4">
            <div class="w-14 h-14 rounded-full bg-brand-500/20 flex items-center justify-center font-display text-xl text-brand-600">JL</div>
            <div>
              <p class="font-body font-700 text-surface-900 text-base">Jasmine L.</p>
              <p class="font-body text-sm text-surface-800/50">Cleaner · Austin, TX</p>
            </div>
          </div>
          <p class="font-body text-base text-surface-800/70 leading-relaxed italic">"I set my own rates and actually take home what I charge. My clients pay less too because I'm not padding the quote to offset platform cuts."</p>
          <div class="mt-auto pt-4 border-t border-surface-200 flex items-baseline gap-2">
            <span class="font-display text-2xl text-brand-500">$2,100</span>
            <span class="font-body text-sm text-surface-800/45">extra kept per year</span>
          </div>
        </div>

        <!-- Worker card 3 -->
        <div class="bg-surface-50 border border-surface-200 rounded-2xl p-7 flex flex-col gap-5 hover:shadow-lg transition-shadow duration-200">
          <div class="flex items-center gap-4">
            <div class="w-14 h-14 rounded-full bg-brand-500/20 flex items-center justify-center font-display text-xl text-brand-600">DT</div>
            <div>
              <p class="font-body font-700 text-surface-900 text-base">Devon T.</p>
              <p class="font-body text-sm text-surface-800/50">Mover · Atlanta, GA</p>
            </div>
          </div>
          <p class="font-body text-base text-surface-800/70 leading-relaxed italic">"I did the math: one year on Tasq vs. my old platform. I kept an extra $4k. That's rent money. Nobody told me how bad it was until I saw it side-by-side."</p>
          <div class="mt-auto pt-4 border-t border-surface-200 flex items-baseline gap-2">
            <span class="font-display text-2xl text-brand-500">$4,080</span>
            <span class="font-body text-sm text-surface-800/45">extra kept per year</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================================
       COMPARISON TABLE — Dark dramatic, the killer argument
       ================================================================ -->
  <section id="why-tasq" class="bg-surface-900 py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-12">
      <p class="font-body text-sm font-600 uppercase tracking-widest text-brand-500 mb-4">Do the math</p>
      <h2 class="font-display text-4xl md:text-5xl lg:text-6xl text-white max-w-2xl leading-[1.1] mb-4">
        Why Tasq wins on every job
      </h2>
      <p class="font-body text-base text-white/50 mb-14 max-w-xl">On $1,000 of monthly gig work, the fee difference is the difference between making rent and not.</p>

      <!-- Table -->
      <div class="overflow-x-auto rounded-2xl border border-white/10">
        <table class="w-full text-sm font-body border-collapse min-w-[560px]">
          <thead>
            <tr class="bg-white/5">
              <th class="text-left px-6 py-4 font-600 text-white/50 uppercase tracking-wide text-xs w-1/4">Platform</th>
              <th class="text-center px-6 py-4 font-600 text-white/50 uppercase tracking-wide text-xs">Fee</th>
              <th class="text-center px-6 py-4 font-600 text-white/50 uppercase tracking-wide text-xs">You keep on $1k/mo</th>
              <th class="text-center px-6 py-4 font-600 text-white/50 uppercase tracking-wide text-xs">Direct messaging</th>
              <th class="text-center px-6 py-4 font-600 text-white/50 uppercase tracking-wide text-xs">Transparent pricing</th>
            </tr>
          </thead>
          <tbody>
            <!-- Tasq row — highlighted -->
            <tr class="bg-brand-500/10 border-b border-white/5">
              <td class="px-6 py-5">
                <span class="font-display text-base text-brand-500">Tasq</span>
                <span class="ml-2 inline-block px-2 py-0.5 text-[10px] font-700 bg-brand-500 text-surface-950 rounded uppercase tracking-wide">Best</span>
              </td>
              <td class="px-6 py-5 text-center">
                <span class="font-display text-xl text-brand-500">5%</span>
              </td>
              <td class="px-6 py-5 text-center">
                <span class="font-display text-xl text-brand-500">$950</span>
              </td>
              <td class="px-6 py-5 text-center">
                <svg class="check-amber inline w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </td>
              <td class="px-6 py-5 text-center">
                <svg class="check-amber inline w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </td>
            </tr>
            <!-- TaskRabbit -->
            <tr class="border-b border-white/5 hover:bg-white/3 transition-colors">
              <td class="px-6 py-4 text-white/70 font-500">TaskRabbit</td>
              <td class="px-6 py-4 text-center text-white/50">15–30%</td>
              <td class="px-6 py-4 text-center text-white/50">$700–850</td>
              <td class="px-6 py-4 text-center">
                <svg class="check-muted inline w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </td>
              <td class="px-6 py-4 text-center">
                <svg class="check-muted inline w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </td>
            </tr>
            <!-- Thumbtack -->
            <tr class="border-b border-white/5 hover:bg-white/3 transition-colors">
              <td class="px-6 py-4 text-white/70 font-500">Thumbtack</td>
              <td class="px-6 py-4 text-center text-white/50">~20% + lead fees</td>
              <td class="px-6 py-4 text-center text-white/50">~$750</td>
              <td class="px-6 py-4 text-center">
                <svg class="check-muted inline w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </td>
              <td class="px-6 py-4 text-center">
                <svg class="check-muted inline w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </td>
            </tr>
            <!-- Handy -->
            <tr class="hover:bg-white/3 transition-colors">
              <td class="px-6 py-4 text-white/70 font-500">Handy</td>
              <td class="px-6 py-4 text-center text-white/50">~25–35%</td>
              <td class="px-6 py-4 text-center text-white/50">$650–750</td>
              <td class="px-6 py-4 text-center">
                <svg class="check-muted inline w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </td>
              <td class="px-6 py-4 text-center">
                <svg class="check-muted inline w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <p class="mt-6 text-white/30 text-xs font-body">Fee estimates based on publicly available data, Q4 2024. "You keep" calculated on $1,000 gross monthly earnings at midpoint rates.</p>
    </div>
  </section>

  <!-- ================================================================
       TASK CATEGORIES — Warm cream, what you can post
       ================================================================ -->
  <section class="bg-surface-50 py-24 md:py-28 border-t border-surface-200">
    <div class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-12">
      <p class="font-body text-sm font-600 uppercase tracking-widest text-brand-500 mb-4">Every task covered</p>
      <h2 class="font-display text-4xl md:text-5xl text-surface-900 max-w-xl leading-[1.1] mb-14">
        Whatever needs doing, someone on Tasq can do it
      </h2>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
        <!-- Mounting & Assembly -->
        <div class="bg-surface-100 hover:bg-brand-50 border border-surface-200 hover:border-brand-200 rounded-xl p-5 flex flex-col items-center gap-3 text-center transition-colors duration-150 cursor-default">
          <div class="w-10 h-10 rounded-lg bg-brand-500/15 flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="oklch(0.65 0.16 72)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
          </div>
          <span class="font-body text-sm font-600 text-surface-900">Assembly</span>
        </div>

        <!-- Cleaning -->
        <div class="bg-surface-100 hover:bg-brand-50 border border-surface-200 hover:border-brand-200 rounded-xl p-5 flex flex-col items-center gap-3 text-center transition-colors duration-150 cursor-default">
          <div class="w-10 h-10 rounded-lg bg-brand-500/15 flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="oklch(0.65 0.16 72)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h18v4H3z"/><path d="M12 7v14"/><path d="M8 21h8"/></svg>
          </div>
          <span class="font-body text-sm font-600 text-surface-900">Cleaning</span>
        </div>

        <!-- Moving -->
        <div class="bg-surface-100 hover:bg-brand-50 border border-surface-200 hover:border-brand-200 rounded-xl p-5 flex flex-col items-center gap-3 text-center transition-colors duration-150 cursor-default">
          <div class="w-10 h-10 rounded-lg bg-brand-500/15 flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="oklch(0.65 0.16 72)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="13" x="6" y="4" rx="2"/><path d="M6 15H2"/><path d="M22 15h-4"/><path d="M6 9H2"/><path d="M22 9h-4"/></svg>
          </div>
          <span class="font-body text-sm font-600 text-surface-900">Moving</span>
        </div>

        <!-- Yard Work -->
        <div class="bg-surface-100 hover:bg-brand-50 border border-surface-200 hover:border-brand-200 rounded-xl p-5 flex flex-col items-center gap-3 text-center transition-colors duration-150 cursor-default">
          <div class="w-10 h-10 rounded-lg bg-brand-500/15 flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="oklch(0.65 0.16 72)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V11"/><path d="M5 3l7 8 7-8"/><path d="M3 21h18"/></svg>
          </div>
          <span class="font-body text-sm font-600 text-surface-900">Yard Work</span>
        </div>

        <!-- Handyman -->
        <div class="bg-surface-100 hover:bg-brand-50 border border-surface-200 hover:border-brand-200 rounded-xl p-5 flex flex-col items-center gap-3 text-center transition-colors duration-150 cursor-default">
          <div class="w-10 h-10 rounded-lg bg-brand-500/15 flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="oklch(0.65 0.16 72)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h20"/><path d="M5 20V8l7-5 7 5v12"/><path d="M9 20v-5h6v5"/></svg>
          </div>
          <span class="font-body text-sm font-600 text-surface-900">Handyman</span>
        </div>

        <!-- Errands -->
        <div class="bg-surface-100 hover:bg-brand-50 border border-surface-200 hover:border-brand-200 rounded-xl p-5 flex flex-col items-center gap-3 text-center transition-colors duration-150 cursor-default">
          <div class="w-10 h-10 rounded-lg bg-brand-500/15 flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="oklch(0.65 0.16 72)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
          </div>
          <span class="font-body text-sm font-600 text-surface-900">Errands</span>
        </div>
      </div>

      <p class="mt-8 text-surface-800/40 text-sm font-body">+ 40 more categories. If it needs doing, post it.</p>
    </div>
  </section>

  <!-- ================================================================
       JOIN CTA — Dark, final rallying cry
       ================================================================ -->
  <section id="join" class="bg-surface-950 py-24 md:py-32 relative overflow-hidden">
    <!-- Gradient echo of hero -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
